# .env.example — copy to .env and fill in your values.
# All variables must be prefixed with VALOCOACH_ to be picked up by the CLI.
VALOCOACH_RIOT_NAME=YourName
VALOCOACH_RIOT_TAG=NA1
VALOCOACH_RIOT_REGION=na
VALOCOACH_HENRIKDEV_API_KEY=your_key_here
VALOCOACH_OLLAMA_MODEL=qwen3:8b
VALOCOACH_OLLAMA_HOST=http://localhost:11434
VALOCOACH_LLM_TEMPERATURE=0.6
VALOCOACH_LLM_MAX_TOKENS=3000
